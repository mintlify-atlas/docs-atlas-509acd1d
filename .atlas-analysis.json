  "keyFeatures": [
    "Time-series partitioned PostgreSQL for high-volume telemetry data",
    "JWT-based authentication with Passport",
    "Multi-database architecture (PostgreSQL + MongoDB)",
    "Automated daily partition management with scheduled jobs",
    "Comprehensive vehicle tracking data model with 50+ attributes",
    "PostGIS geospatial indexing for location queries"
  ],
  "publicApiSurface": [
    "POST /auth/login - Authenticate user and receive JWT token",
    "GET /points - Query vehicle tracking points",
    "POST /points - Create new tracking point",
    "PartitionManagerService.createPartitionForDate() - Create daily partition",
    "PartitionManagerService.dropPartitionDaysAgo() - Remove old partition",
    "PointsService - Service layer for points CRUD operations",
    "UserService.findOneDni() - Find user by DNI",
    "JwtStrategy - JWT authentication strategy"
  ]
